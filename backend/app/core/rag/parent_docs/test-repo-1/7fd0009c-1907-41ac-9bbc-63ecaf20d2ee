{"lc": 1, "type": "constructor", "id": ["langchain", "schema", "document", "Document"], "kwargs": {"metadata": {"source": "routers\\mentor.py"}, "page_content": "\"\"\"\napp/routers/mentor.py\n\nExposes the full RAG + Gemini loop as a real endpoint your frontend's\nAI Mentor Chat page can call directly. This is separate from\n/api/rag/query (which only returns raw chunks) \u2014 this one returns a\nreal generated answer.\n\"\"\"\n\nfrom fastapi import APIRouter, HTTPException\n\nfrom app.core.rag.generate import ask_mentor\nfrom app.schemas.mentor import MentorAskRequest, MentorAskResponse\n\nrouter = APIRouter(prefix=\"/api/mentor\", tags=[\"mentor\"])\n\n\n@router.post(\"/ask\", response_model=MentorAskResponse)\ndef ask(request: MentorAskRequest):\n    try:\n        result = ask_mentor(request.question, top_k=request.top_k)\n    except RuntimeError as e:\n        raise HTTPException(status_code=500, detail=str(e))\n    return MentorAskResponse(answer=result[\"answer\"], sources=result[\"sources\"])", "type": "Document"}}